                                <Button x:Name="SettingsShortcutsNavButton" Tag="Shortcuts" Click="SettingsNavButton_Click" HorizontalContentAlignment="Left" Padding="12,10" CornerRadius="12" Background="Transparent" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE765;" FontSize="14" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                        <TextBlock x:Name="SettingsShortcutsNavText" VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="SettingsAboutNavButton" Tag="About" Click="SettingsNavButton_Click" HorizontalContentAlignment="Left" Padding="12,10" CornerRadius="12" Background="Transparent" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                        <TextBlock x:Name="SettingsAboutNavText" VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Border Grid.Row="2" Background="{ThemeResource ShellPanelAltBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="18" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsTipTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="14" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    <TextBlock x:Name="SettingsTipBodyText" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Column="1" x:Name="SettingsScrollViewer" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14" Padding="0,0,8,12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="SettingsPageTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="32" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                <Button Grid.Column="1" Content="×" Click="SettingsCancelButton_Click" MinWidth="32" MinHeight="32" Padding="0" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top" />
                            </Grid>

                            <Border x:Name="SettingsGeneralCard" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                                <StackPanel Spacing="14">
                                    <TextBlock x:Name="AppearanceSettingsTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="ThemeSettingLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <ComboBox x:Name="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged" />
                                        <TextBlock x:Name="ThemeSettingHelpText" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="11" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="LanguageSettingsTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                        <TextBlock x:Name="LanguageSettingLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <ComboBox x:Name="LanguageComboBox" SelectionChanged="LanguageComboBox_SelectionChanged" />
                                        <TextBlock x:Name="LanguageSettingHelpText" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="11" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock x:Name="SettingsRestartHintText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsCaptureCard" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="CaptureSettingsTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    <TextBlock x:Name="CaptureSettingLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                    <ToggleSwitch x:Name="AutoImportClipboardToggleSwitch" Toggled="AutoImportClipboardToggleSwitch_Toggled" />
                                    <TextBlock x:Name="CaptureSettingHelpText" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="11" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="ExportSection" Visibility="Visible" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="24">
                                <StackPanel Spacing="14">
                                    <TextBlock x:Name="ExportPageTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="24" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    <TextBlock x:Name="ExportPageSummaryText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />

                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="ExportTemplateLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <ComboBox x:Name="ExportTemplateComboBox" SelectionChanged="ExportTemplateComboBox_SelectionChanged" />
                                        <TextBlock x:Name="ExportTemplateValueText" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="11" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="ExportFormatLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <ComboBox x:Name="ExportFormatComboBox" SelectionChanged="ExportFormatComboBox_SelectionChanged" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="ExportAudienceLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBox x:Name="ExportAudienceTextBox" TextChanged="ExportAudienceTextBox_TextChanged" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="ExportAuthorLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBox x:Name="ExportAuthorTextBox" TextChanged="ExportAuthorTextBox_TextChanged" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="ExportVersionLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <TextBox x:Name="ExportVersionTextBox" TextChanged="ExportVersionTextBox_TextChanged" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock x:Name="ExportFolderLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ExportFolderTextBox" TextChanged="ExportFolderTextBox_TextChanged" />
                                            <Button x:Name="BrowseExportFolderButton" Grid.Column="1" Click="BrowseExportFolderButton_Click" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="ExportPngButton" Click="ExportButton_Click" />
                                        <Button x:Name="ExportAllFormatsButton" Click="ExportAllFormatsButton_Click" />
                                        <Button x:Name="ExportMarkdownButton" Click="ExportMarkdownButton_Click" />
                                        <Button x:Name="ExportHtmlButton" Click="ExportHtmlButton_Click" />
                                        <Button x:Name="ExportPdfButton" Click="ExportPdfButton_Click" />
                                        <Button x:Name="ExportDocxButton" Click="ExportDocxButton_Click" />
                                    </StackPanel>

                                    <Border Background="{ThemeResource ShellPanelAltBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="18" Padding="16">
                                        <StackPanel Spacing="12">
                                            <TextBlock x:Name="ExportPreviewTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                            <TextBlock x:Name="ExportPreviewSummaryText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                            <ListView x:Name="ExportStepsListView" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="PublishSection" Visibility="Visible" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="24">
                                <StackPanel Spacing="14">
                                    <TextBlock x:Name="PublishPageTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="24" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    <TextBlock x:Name="PublishPageSummaryText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />

                                    <Border Background="{ThemeResource ShellPanelAltBrush}" CornerRadius="18" Padding="16">
                                        <StackPanel Spacing="10">
                                            <TextBlock x:Name="OcrSectionTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                            <TextBlock x:Name="OcrSectionHelpText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{ThemeResource ShellPanelAltBrush}" CornerRadius="18" Padding="16">
                                        <StackPanel Spacing="12">
                                            <TextBlock x:Name="NotionSectionTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                            <TextBlock x:Name="NotionSectionHelpText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="NotionParentPageLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                <TextBox x:Name="NotionParentPageIdTextBox" TextChanged="NotionParentPageIdTextBox_TextChanged" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="NotionTokenLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                <PasswordBox x:Name="NotionTokenPasswordBox" />
                                            </StackPanel>
                                            <Button x:Name="PublishNotionButton" Click="PublishNotionButton_Click" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{ThemeResource ShellPanelAltBrush}" CornerRadius="18" Padding="16">
                                        <StackPanel Spacing="12">
                                            <TextBlock x:Name="ConfluenceSectionTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                            <TextBlock x:Name="ConfluenceSectionHelpText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="ConfluenceBaseUrlLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                <TextBox x:Name="ConfluenceBaseUrlTextBox" TextChanged="ConfluenceBaseUrlTextBox_TextChanged" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="ConfluenceSpaceKeyLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                <TextBox x:Name="ConfluenceSpaceKeyTextBox" TextChanged="ConfluenceSpaceKeyTextBox_TextChanged" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="ConfluenceParentPageLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                <TextBox x:Name="ConfluenceParentPageIdTextBox" TextChanged="ConfluenceParentPageIdTextBox_TextChanged" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="ConfluenceEmailLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                <TextBox x:Name="ConfluenceEmailTextBox" TextChanged="ConfluenceEmailTextBox_TextChanged" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="ConfluenceTokenLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                <PasswordBox x:Name="ConfluenceTokenPasswordBox" />
                                            </StackPanel>
                                            <Button x:Name="PublishConfluenceButton" Click="PublishConfluenceButton_Click" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{ThemeResource ShellPanelAltBrush}" CornerRadius="18" Padding="16">
                                        <StackPanel Spacing="12">
                                            <TextBlock x:Name="SharePointSectionTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                            <TextBlock x:Name="SharePointSectionHelpText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                            <StackPanel Spacing="6">
                                                <TextBlock x:Name="SharePointFolderLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="SharePointSyncFolderTextBox" TextChanged="SharePointSyncFolderTextBox_TextChanged" />
                                                    <Button x:Name="BrowseSharePointFolderButton" Grid.Column="1" Click="BrowseSharePointFolderButton_Click" />
                                                </Grid>
                                            </StackPanel>
                                            <Button x:Name="PublishSharePointButton" Click="PublishSharePointButton_Click" HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border x:Name="SettingsAboutCard" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="SettingsAboutTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    <TextBlock x:Name="SettingsAboutBodyText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,6,0,0">
                                <Button x:Name="SettingsCancelButton" Click="SettingsCancelButton_Click" />
                                <Button x:Name="SettingsSaveButton" Click="SettingsSaveButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

        <Border Grid.Row="3" Margin="16,0,16,12" Background="Transparent" BorderThickness="0" Padding="0" IsHitTestVisible="False">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Foreground="{ThemeResource ShellMutedTextBrush}" TextTrimming="CharacterEllipsis" FontSize="12" IsHitTestVisible="False" />
                <TextBlock x:Name="AnnotationCountText" Grid.Column="1" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="12" IsHitTestVisible="False" />
            </Grid>
        </Border>
    </Grid>
</Grid>
</Window>


