<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SnapSlate.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:automation="using:Microsoft.UI.Xaml.Automation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SnapSlate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    Title="SnapSlate"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

        <Grid x:Name="RootGrid" Background="{ThemeResource ShellBackgroundBrush}" PreviewKeyDown="RootGrid_PreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="SnapSlate">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Border Grid.Row="1" Visibility="Collapsed" />

        <Grid Grid.Row="2">
            <Grid x:Name="CaptureSection" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Padding="20" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="24">
                            <StackPanel Spacing="16">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock x:Name="CapturePageTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="32" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                        <TextBlock x:Name="CapturePageSummaryText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="×" Click="SettingsCancelButton_Click" MinWidth="32" MinHeight="32" Padding="0" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                </Grid>
                                <Button x:Name="CaptureQuickImportButton" Click="ImportScreenshotButton_Click" HorizontalAlignment="Left" />

                                <StackPanel Spacing="12">
                                    <TextBlock x:Name="CaptureHowTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                    <TextBlock x:Name="CaptureHowBodyText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{ThemeResource ShellPanelAltBrush}" CornerRadius="18" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="CaptureStepOneTitleText" FontWeight="SemiBold" />
                                            <TextBlock x:Name="CaptureStepOneBodyText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="{ThemeResource ShellPanelAltBrush}" CornerRadius="18" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="CaptureStepTwoTitleText" FontWeight="SemiBold" />
                                            <TextBlock x:Name="CaptureStepTwoBodyText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{ThemeResource ShellPanelAltBrush}" CornerRadius="18" Padding="14">
                                        <StackPanel Spacing="6">
                                            <TextBlock x:Name="CaptureStepThreeTitleText" FontWeight="SemiBold" />
                                            <TextBlock x:Name="CaptureStepThreeBodyText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="24">
                            <StackPanel Spacing="16">
                                <TextBlock x:Name="CaptureShortcutsTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                <StackPanel Spacing="10">
                                    <TextBlock x:Name="CaptureShortcutOneText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="CaptureShortcutTwoText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="CaptureShortcutThreeText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="CaptureShortcutFourText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                    <TextBlock x:Name="CaptureShortcutFiveText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Background="{ThemeResource ShellPanelAltBrush}" CornerRadius="18" Padding="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock x:Name="HelpShortcutsTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="16" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                        <ListView x:Name="HelpShortcutsListView" HorizontalContentAlignment="Stretch" SelectionMode="None" IsItemClickEnabled="False">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{ThemeResource ShellBackgroundBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="8" Padding="8,4" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding Key}" FontSize="12" FontFamily="Bahnschrift SemiBold SemiConden" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap" Foreground="{ThemeResource ShellMutedTextBrush}" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                                <Border Background="{ThemeResource CanvasBackdropBrush}" CornerRadius="18" Padding="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock x:Name="CaptureStatusTitleText" FontWeight="SemiBold" />
                                        <TextBlock x:Name="CaptureStatusBodyText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Grid x:Name="ProcedureSection" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="22" Margin="12,12,12,10" Padding="14,10">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <MenuBar x:Name="AppMenuBar" VerticalAlignment="Center" Background="Transparent" Padding="0">
                                <MenuBarItem x:Name="FileMenuBarItem" Title="Fichier">
                                    <MenuFlyoutItem x:Name="NewProjectMenuItem" Click="NewProjectButton_Click" />
                                    <MenuFlyoutItem x:Name="OpenProjectMenuItem" Click="OpenProjectButton_Click" />
                                    <MenuFlyoutItem x:Name="SaveProjectMenuItem" Click="SaveProjectButton_Click" />
                                </MenuBarItem>
                                <MenuBarItem x:Name="EditMenuBarItem" Title="Édition">
                                    <MenuFlyoutItem x:Name="UndoMenuItem" Click="UndoButton_Click" />
                                    <MenuFlyoutItem x:Name="RedoMenuItem" Click="RedoButton_Click" />
                                </MenuBarItem>
                                <MenuBarItem x:Name="ImageMenuBarItem" Title="Image">
                                    <MenuFlyoutItem x:Name="ImportScreenshotMenuItem" Click="ImportScreenshotButton_Click" />
                                    <MenuFlyoutItem x:Name="OcrMenuItem" Click="OcrButton_Click" />
                                </MenuBarItem>
                                <MenuBarItem x:Name="ExportMenuBarItem" Title="Export">
                                    <MenuFlyoutItem x:Name="ExportCurrentMenuItem" Click="ExportCurrentMenuItem_Click" />
                                    <MenuFlyoutItem x:Name="ExportAllFormatsMenuItem" Click="ExportAllFormatsButton_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="ExportMarkdownMenuItem" Click="ExportMarkdownButton_Click" />
                                    <MenuFlyoutItem x:Name="ExportHtmlMenuItem" Click="ExportHtmlButton_Click" />
                                    <MenuFlyoutItem x:Name="ExportPdfMenuItem" Click="ExportPdfButton_Click" />
                                    <MenuFlyoutItem x:Name="ExportDocxMenuItem" Click="ExportDocxButton_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="PublishNotionMenuItem" Click="PublishNotionButton_Click" />
                                    <MenuFlyoutItem x:Name="PublishConfluenceMenuItem" Click="PublishConfluenceButton_Click" />
                                    <MenuFlyoutItem x:Name="PublishSharePointMenuItem" Click="PublishSharePointButton_Click" />
                                </MenuBarItem>
                                <MenuBarItem x:Name="HelpMenuBarItem" Title="Aide">
                                    <MenuFlyoutItem x:Name="OpenHelpMenuItem" Click="ShowHelpSectionMenuItem_Click" />
                                    <MenuFlyoutItem x:Name="ReturnToProcedureMenuItem" Click="ReturnToProcedureMenuItem_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="PrintScreenMenuItem" Click="CaptureShortcutMenuItem_Click" Tag="PrintScreen" />
                                    <MenuFlyoutItem x:Name="AltPrintScreenMenuItem" Click="CaptureShortcutMenuItem_Click" Tag="AltPrintScreen" />
                                    <MenuFlyoutItem x:Name="WinPrintScreenMenuItem" Click="CaptureShortcutMenuItem_Click" Tag="WinPrintScreen" />
                                    <MenuFlyoutItem x:Name="WinShiftSMenuItem" Click="CaptureShortcutMenuItem_Click" Tag="WinShiftS" />
                                    <MenuFlyoutItem x:Name="FnWinSpaceMenuItem" Click="CaptureShortcutMenuItem_Click" Tag="FnWinSpace" />
                                </MenuBarItem>
                            </MenuBar>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                <TextBox x:Name="DocumentTitleTextBox" Width="260" MinWidth="180" Background="Transparent" BorderThickness="0" Padding="0" FontSize="17" FontWeight="SemiBold" HorizontalContentAlignment="Center" TextChanged="DocumentTitleTextBox_TextChanged" />
                                <Button x:Name="DocumentTitleEditButton" Click="DocumentTitleEditButton_Click" MinWidth="30" MinHeight="30" Padding="0" CornerRadius="8" Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                                    <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Background="{ThemeResource ShellBackgroundBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="18" Padding="12,8">
                            <Grid ColumnSpacing="14" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="ToolbarZoomOutButton" Click="ZoomOutButton_Click" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Button x:Name="ToolbarZoomResetButton" Click="ZoomResetButton_Click" />
                                    <Button x:Name="ToolbarZoomInButton" Click="ZoomInButton_Click" />
                                    <Button x:Name="ToolbarFitButton" Click="FitToViewportButton_Click" />
                                </StackPanel>

                                <Button Grid.Column="2" x:Name="ToolbarStepsButton" Click="CollapseStepsButton_Click" Margin="4,0,0,0" MinHeight="34" Padding="12,6" CornerRadius="10" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" />

                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock x:Name="ToolbarPaletteLabelText" VerticalAlignment="Center" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                    <ComboBox x:Name="ToolbarPaletteComboBox" Width="188" SelectionChanged="ToolbarPaletteComboBox_SelectionChanged">
                                        <ComboBox.Resources>
                                            <DataTemplate x:Key="PaletteComboTemplate" x:DataType="local:GradientPaletteDefinition">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <Border Width="16" Height="16" CornerRadius="8" Background="{Binding DisplayBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" />
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.Resources>
                                        <ComboBox.ItemTemplate>
                                            <StaticResource ResourceKey="PaletteComboTemplate" />
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock x:Name="ShadeSectionTitleText" Visibility="Collapsed" />
                                    <StackPanel x:Name="ShadeStrip" Orientation="Horizontal" Spacing="4" />
                                </StackPanel>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock x:Name="ToolbarOpacityLabelText" VerticalAlignment="Center" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                    <Slider x:Name="ToolbarOpacitySlider" Width="124" Minimum="0.1" Maximum="1" Value="1" StepFrequency="0.05" ValueChanged="OpacitySlider_ValueChanged" />
                                    <TextBlock x:Name="ToolbarOpacityValueText" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock x:Name="ToolbarDocumentLabelText" VerticalAlignment="Center" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                    <ComboBox x:Name="ToolbarDocumentComboBox" Width="124" DisplayMemberPath="StepTitle" SelectionChanged="ToolbarDocumentComboBox_SelectionChanged" />
                                </StackPanel>

                                <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="4" VerticalAlignment="Center">
                                    <TextBlock x:Name="ToolbarCurrentToolLabelText" VerticalAlignment="Center" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                    <TextBlock x:Name="ToolbarCurrentToolText" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                </StackPanel>

                                <Button Grid.Column="8" x:Name="ToolbarToolPickerButton" Click="ToolPickerButton_Click" Visibility="Collapsed" />
                                <Button Grid.Column="9" x:Name="SettingsMenuButton" Click="SettingsButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center" MinHeight="34" Padding="12,6" CornerRadius="10" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="{ThemeResource ShellBackgroundBrush}" Padding="12">
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="1" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="StepsPaneColumn" Width="240" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition x:Name="InspectorPaneColumn" Width="300" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="12">
                                <Grid RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid x:Name="StepsHeaderPanel" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock x:Name="StepsPaneTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                            <TextBlock x:Name="StepsPaneHintText" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="10" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                            <Button x:Name="AddStepButton" Click="NewDemoTabButton_Click" />
                                            <Button x:Name="CollapseStepsButton" Click="CollapseStepsButton_Click" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="1">
                                        <ListView
                                            x:Name="DocumentTabsListView"
                                            SelectionChanged="DocumentTabsListView_SelectionChanged"
                                            SelectionMode="Single"
                                            AllowDrop="True"
                                            CanDragItems="True"
                                            CanReorderItems="True"
                                            IsSwipeEnabled="False"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                                            DragItemsStarting="DocumentTabsListView_DragItemsStarting"
                                            DragItemsCompleted="DocumentTabsListView_DragItemsCompleted">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsStackPanel Orientation="Vertical" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0,0,0,8" />
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="18" Padding="10">
                                                        <Grid ColumnSpacing="10" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="56" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="24" Height="24" Background="{ThemeResource ToolSelectedBrush}" CornerRadius="12">
                                                                <TextBlock Text="{Binding StepNumber}" Foreground="{ThemeResource ToolSelectedTextBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <Border Grid.Column="1" Background="{ThemeResource CanvasBackdropBrush}" CornerRadius="12" Padding="3">
                                                                <Image Source="{Binding ThumbnailSource}" Stretch="UniformToFill" />
                                                            </Border>
                                                            <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding TabTitle}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource ShellStrongTextBrush}" TextTrimming="CharacterEllipsis" />
                                                                <Border Background="{ThemeResource ShellBackgroundBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="999" Padding="8,3" HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding StepNote}" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                                </Border>
                                                            </StackPanel>
                                                            <Button Grid.Column="3" Tag="{Binding}" Click="StepMoreButton_Click" Content="⋯" MinWidth="28" MinHeight="28" Padding="0" Background="Transparent" BorderBrush="Transparent" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <ListView
                                            x:Name="DocumentTabsCompactListView"
                                            Visibility="Collapsed"
                                            SelectionChanged="DocumentTabsListView_SelectionChanged"
                                            SelectionMode="Single"
                                            AllowDrop="True"
                                            CanDragItems="True"
                                            CanReorderItems="True"
                                            IsSwipeEnabled="False"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                                            DragItemsStarting="DocumentTabsListView_DragItemsStarting"
                                            DragItemsCompleted="DocumentTabsListView_DragItemsCompleted">
                                            <ListView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsStackPanel Orientation="Vertical" />
                                                </ItemsPanelTemplate>
                                            </ListView.ItemsPanel>
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0,0,0,8" />
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="14" Padding="6">
                                                        <Grid RowSpacing="5">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="40" />
                                                            </Grid.RowDefinitions>
                                                            <Border Width="22" Height="22" Background="{ThemeResource ToolSelectedBrush}" CornerRadius="11" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding StepNumber}" Foreground="{ThemeResource ToolSelectedTextBrush}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <Border Grid.Row="1" Background="{ThemeResource CanvasBackdropBrush}" CornerRadius="10" Padding="2">
                                                                <Image Source="{Binding ThumbnailSource}" Stretch="UniformToFill" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="14">
                                <Grid RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                            <Grid RowSpacing="8" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="CanvasSummaryTitleText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="18" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                            <TextBlock x:Name="CanvasSummaryText" Foreground="{ThemeResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
                                            <TextBlock x:Name="CanvasFileLabelText" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                            <TextBlock x:Name="CanvasFileNameText" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="1" Background="{ThemeResource CanvasBackdropBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="CanvasPreviewLabelText" VerticalAlignment="Center" Foreground="{ThemeResource ShellMutedTextBrush}" Visibility="Collapsed" />
                                                <TextBlock x:Name="ImageSourceText" Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource ShellMutedTextBrush}" Visibility="Collapsed" />
                                            </Grid>

                                            <ScrollViewer
                                                x:Name="CanvasScrollViewer"
                                                Grid.Row="1"
                                                ZoomMode="Enabled"
                                                MinZoomFactor="0.5"
                                                MaxZoomFactor="2.0"
                                                HorizontalScrollBarVisibility="Auto"
                                                VerticalScrollBarVisibility="Auto">
                                                <Grid
                                                    x:Name="PreviewViewport"
                                                    Width="1360"
                                                    Height="820"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                    <Rectangle Fill="{ThemeResource CanvasPatternBrush}" RadiusX="20" RadiusY="20" />
                                                    <Grid x:Name="SceneHost" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" PointerMoved="SceneHost_PointerMoved" PointerPressed="SceneHost_PointerPressed" PointerReleased="SceneHost_PointerReleased">
                                                        <Grid.RenderTransform>
                                                            <TransformGroup>
                                                                <ScaleTransform x:Name="SceneScaleTransform" ScaleX="1" ScaleY="1" />
                                                                <TranslateTransform x:Name="SceneTransform" />
                                                            </TransformGroup>
                                                        </Grid.RenderTransform>

                                                        <Grid x:Name="PlaceholderPanel" Padding="36" IsHitTestVisible="False">
                                                            <Border Background="#FFF6F8FC" BorderBrush="#FFDDE4EE" BorderThickness="1" CornerRadius="26" />
                                                            <Grid Margin="26" RowSpacing="18">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="*" />
                                                                </Grid.RowDefinitions>

                                                                <StackPanel Spacing="10">
                                                                    <TextBlock Text="Demo documentaire" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellMutedTextBrush}" />
                                                                    <TextBlock x:Name="PlaceholderTitleText" Text="Lorem Ipsum" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="34" Foreground="{ThemeResource ShellStrongTextBrush}" />
                                                                    <TextBlock x:Name="PlaceholderBodyText" Width="920" Text="Maquette éditoriale complète pour la démonstration et les annotations. La page combine un article, une colonne latérale, un visuel principal et des encadrés pour donner un vrai contexte de production." TextWrapping="Wrap" Foreground="{ThemeResource ShellMutedTextBrush}" FontSize="13" />
