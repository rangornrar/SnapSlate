<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SnapSlate.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SnapSlate"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SnapSlate"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource ShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="SnapSlate">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Padding="20" RowSpacing="16" ColumnSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="310" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.RowSpan="2"
                Grid.Column="0"
                Background="{ThemeResource ShellPanelBrush}"
                BorderBrush="{ThemeResource ShellStrokeBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <TextBlock
                            FontFamily="Bahnschrift SemiBold SemiConden"
                            FontSize="30"
                            Foreground="{ThemeResource ShellStrongTextBrush}"
                            Text="SnapSlate" />
                        <TextBlock
                            Foreground="{ThemeResource ShellMutedTextBrush}"
                            Text="Win + Shift + S alimente automatiquement de nouveaux onglets tant que l'application reste ouverte."
                            TextWrapping="Wrap" />

                        <TextBlock
                            FontFamily="Bahnschrift SemiBold SemiConden"
                            FontSize="16"
                            Foreground="{ThemeResource ShellStrongTextBrush}"
                            Text="Outils" />
                        <Button x:Name="CropToolButton" Click="ToolButton_Click" Tag="Crop" Content="Crop" />
                        <Button x:Name="TextToolButton" Click="ToolButton_Click" Tag="Text" Content="Texte" />
                        <Button x:Name="StickerToolButton" Click="ToolButton_Click" Tag="Sticker" Content="Gommette" />
                        <Button x:Name="ArrowStraightToolButton" Click="ToolButton_Click" Tag="ArrowStraight" Content="Fleche droite" />
                        <Button x:Name="ArrowCurvedToolButton" Click="ToolButton_Click" Tag="ArrowCurved" Content="Fleche courbe" />
                        <Button x:Name="RectangleToolButton" Click="ToolButton_Click" Tag="Rectangle" Content="Rectangle" />
                        <Button x:Name="EllipseToolButton" Click="ToolButton_Click" Tag="Ellipse" Content="Ovale" />

                        <TextBlock
                            FontFamily="Bahnschrift SemiBold SemiConden"
                            FontSize="16"
                            Foreground="{ThemeResource ShellStrongTextBrush}"
                            Text="Palettes degradees" />
                        <Grid RowSpacing="8" ColumnSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="SunsetPaletteButton" Grid.Row="0" Grid.Column="0" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientSunsetBrush}" Click="PaletteButton_Click" Tag="Sunset" />
                            <Button x:Name="EmberPaletteButton" Grid.Row="0" Grid.Column="1" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientEmberBrush}" Click="PaletteButton_Click" Tag="Ember" />
                            <Button x:Name="CitrusPaletteButton" Grid.Row="0" Grid.Column="2" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientCitrusBrush}" Click="PaletteButton_Click" Tag="Citrus" />
                            <Button x:Name="MintPaletteButton" Grid.Row="0" Grid.Column="3" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientMintBrush}" Click="PaletteButton_Click" Tag="Mint" />
                            <Button x:Name="LagoonPaletteButton" Grid.Row="0" Grid.Column="4" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientLagoonBrush}" Click="PaletteButton_Click" Tag="Lagoon" />
                            <Button x:Name="SkyPaletteButton" Grid.Row="1" Grid.Column="0" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientSkyBrush}" Click="PaletteButton_Click" Tag="Sky" />
                            <Button x:Name="OceanPaletteButton" Grid.Row="1" Grid.Column="1" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientOceanBrush}" Click="PaletteButton_Click" Tag="Ocean" />
                            <Button x:Name="RosePaletteButton" Grid.Row="1" Grid.Column="2" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientRoseBrush}" Click="PaletteButton_Click" Tag="Rose" />
                            <Button x:Name="BerryPaletteButton" Grid.Row="1" Grid.Column="3" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientBerryBrush}" Click="PaletteButton_Click" Tag="Berry" />
                            <Button x:Name="GrapePaletteButton" Grid.Row="1" Grid.Column="4" Width="44" Height="44" CornerRadius="14" Background="{StaticResource GradientGrapeBrush}" Click="PaletteButton_Click" Tag="Grape" />
                        </Grid>
                        <TextBlock x:Name="PaletteSummaryText" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Palette active : sunset note" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border
                Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="{ThemeResource ShellPanelBrush}"
                BorderBrush="{ThemeResource ShellStrokeBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ListView
                        x:Name="DocumentTabsListView"
                        SelectionChanged="DocumentTabsListView_SelectionChanged"
                        SelectionMode="Single"
                        ScrollViewer.HorizontalScrollMode="Enabled"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Margin" Value="0,0,8,0" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ScreenshotDocument">
                                <Border
                                    MinWidth="190"
                                    Background="{ThemeResource ShellPanelAltBrush}"
                                    BorderBrush="{ThemeResource ShellStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="12,10">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding TabTitle}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock FontSize="12" Foreground="{ThemeResource ShellMutedTextBrush}" Text="{Binding TabSubtitle}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <Button
                                            Grid.Column="1"
                                            Tag="{Binding}"
                                            Click="CloseDocumentButton_Click"
                                            Content="x"
                                            Width="28"
                                            Height="28"
                                            CornerRadius="14" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Column="1" Click="NewDemoTabButton_Click" Content="Nouvel onglet demo" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Click="ImportScreenshotButton_Click" Content="Importer fichier" />
                    <Button Click="ExportButton_Click" Content="Exporter PNG" />
                    <Button x:Name="ApplyCropButton" Click="ApplyCropButton_Click" IsEnabled="False" Content="Appliquer crop" />
                    <Button x:Name="ResetCropButton" Click="ResetCropButton_Click" IsEnabled="False" Content="Reset crop" />
                    <Button Click="ClearAnnotationsButton_Click" Content="Effacer annotations" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource ShellPanelBrush}"
                    BorderBrush="{ThemeResource ShellStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="24"
                    Padding="16">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontFamily="Bahnschrift SemiBold SemiConden" FontSize="28" Foreground="{ThemeResource ShellStrongTextBrush}" Text="Atelier de screenshot" />
                                <TextBlock x:Name="CanvasSummaryText" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Aucun onglet selectionne." TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Foreground="{ThemeResource ShellMutedTextBrush}" Text="Outil actif" />
                                <TextBlock x:Name="CurrentToolText" FontFamily="Bahnschrift SemiBold SemiConden" FontSize="20" Foreground="{ThemeResource ShellStrongTextBrush}" Text="Fleche droite" />
                            </StackPanel>
                        </Grid>

                        <Viewbox Grid.Row="1" Stretch="Uniform">
                            <Border Background="{ThemeResource CanvasBackdropBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="24" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="56" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Preview surface" />
                                        <TextBlock x:Name="CanvasFileNameText" Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource ShellMutedTextBrush}" Text="capture.png" />
                                    </Grid>

                                    <Grid
                                        x:Name="PreviewViewport"
                                        Grid.Row="1"
                                        Width="1360"
                                        Height="820"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <Grid
                                            x:Name="SceneRoot"
                                            Width="1360"
                                            Height="820"
                                            RenderTransformOrigin="0,0">
                                            <Grid.RenderTransform>
                                                <TranslateTransform x:Name="SceneTransform" />
                                            </Grid.RenderTransform>

                                            <Rectangle Fill="{ThemeResource CanvasPatternBrush}" RadiusX="20" RadiusY="20" />
                                            <Grid x:Name="PlaceholderPanel" Padding="40">
                                                <Grid RowSpacing="16">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="90" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <Rectangle Fill="#FFE7EDF5" RadiusX="16" RadiusY="16" />
                                                    <Grid Grid.Row="1" ColumnSpacing="16">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="300" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="220" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Spacing="16">
                                                            <Rectangle Height="170" Fill="#FFDDE6EF" RadiusX="16" RadiusY="16" />
                                                            <Rectangle Height="140" Fill="#FFF7DFC0" RadiusX="16" RadiusY="16" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="16">
                                                            <Rectangle Height="280" Fill="#FFE3ECF6" RadiusX="18" RadiusY="18" />
                                                            <Rectangle Height="92" Fill="#FFEAF0F6" RadiusX="16" RadiusY="16" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="16">
                                                            <Rectangle Height="150" Fill="#FFDDE7F1" RadiusX="16" RadiusY="16" />
                                                            <Rectangle Height="190" Fill="#FFF2D9E2" RadiusX="16" RadiusY="16" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Grid>

                                            <Image x:Name="ImportedImage" Stretch="Uniform" Visibility="Collapsed" />
                                            <Canvas x:Name="AnnotationCanvas" />
                                            <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
                                                <Rectangle
                                                    x:Name="CropPreview"
                                                    Fill="#1E00C5A7"
                                                    RadiusX="20"
                                                    RadiusY="20"
                                                    Stroke="#FF00C5A7"
                                                    StrokeDashArray="10,6"
                                                    StrokeThickness="4"
                                                    Visibility="Collapsed" />
                                                <Border
                                                    x:Name="CropBadge"
                                                    Background="{ThemeResource OverlayBadgeBrush}"
                                                    CornerRadius="12"
                                                    Padding="10,6"
                                                    Visibility="Collapsed">
                                                    <TextBlock x:Name="CropBadgeText" Foreground="{ThemeResource OverlayBadgeTextBrush}" Text="Crop 0 x 0" />
                                                </Border>
                                            </Canvas>
                                            <Border
                                                x:Name="InteractionSurface"
                                                Background="Transparent"
                                                PointerMoved="InteractionSurface_PointerMoved"
                                                PointerPressed="InteractionSurface_PointerPressed"
                                                PointerReleased="InteractionSurface_PointerReleased" />
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Viewbox>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="{ThemeResource ShellPanelAltBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="20" Padding="16,12">
                    <TextBlock x:Name="StatusText" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Cliquez ou glissez dans la surface pour poser une annotation." />
                </Border>
            </Grid>

            <Border
                Grid.Row="1"
                Grid.Column="2"
                Background="{ThemeResource ShellPanelBrush}"
                BorderBrush="{ThemeResource ShellStrokeBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">
                        <TextBlock FontFamily="Bahnschrift SemiBold SemiConden" FontSize="16" Foreground="{ThemeResource ShellStrongTextBrush}" Text="Proprietes" />
                        <TextBox x:Name="AnnotationTextBox" Header="Libelle" PlaceholderText="Ex: verifier le total" TextChanged="AnnotationTextBox_TextChanged" />
                        <ComboBox x:Name="StickerModeComboBox" Header="Mode gommette" SelectionChanged="StickerModeComboBox_SelectionChanged">
                            <x:String>Numerique</x:String>
                            <x:String>Alphabetique</x:String>
                            <x:String>Texte du champ</x:String>
                        </ComboBox>
                        <CheckBox
                            x:Name="ResetStickerNumberOnColorChangeCheckBox"
                            Checked="ResetStickerNumberOnColorChangeCheckBox_Changed"
                            Unchecked="ResetStickerNumberOnColorChangeCheckBox_Changed"
                            Content="Repartir de 1 ou A quand la couleur change" />
                        <TextBlock x:Name="StickerSequenceText" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Prochaine gommette : 1" />
                        <Slider x:Name="StrokeThicknessSlider" ValueChanged="StrokeThicknessSlider_ValueChanged" />
                        <TextBlock x:Name="StrokeSummaryText" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Trait actuel : 6 px" />
                        <TextBlock x:Name="CropStateText" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Aucun crop applique pour le moment." TextWrapping="Wrap" />
                        <TextBlock x:Name="ImageSourceText" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Source : demo" TextWrapping="Wrap" />
                        <TextBlock Foreground="{ThemeResource ShellMutedTextBrush}" Text="Les onglets affichent une proposition d'enregistrement a la fermeture si le contenu n'a pas ete sauvegarde." TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="20,0,20,20" Background="{ThemeResource ShellPanelBrush}" BorderBrush="{ThemeResource ShellStrokeBrush}" BorderThickness="1" CornerRadius="18" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterText" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Chaque capture Win + Shift + S cree un nouvel onglet." />
                <TextBlock x:Name="AnnotationCountText" Grid.Column="1" Foreground="{ThemeResource ShellMutedTextBrush}" Text="Annotations : 0" />
            </Grid>
        </Border>
    </Grid>
</Window>
